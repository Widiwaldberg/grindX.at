# Wird automatisch von Vercel gesetzt, sobald ein Neon-Postgres-Storage mit dem Projekt verbunden ist.
# Lokal per `vercel env pull .env.local` holen.
DATABASE_URL=

# Wird automatisch von Vercel gesetzt, sobald ein Blob-Storage mit dem Projekt verbunden ist.
BLOB_READ_WRITE_TOKEN=

# Muss manuell gesetzt werden (lokal + in den Vercel Project Settings), z.B. mit:
#   openssl rand -hex 32
JWT_SECRET=
